# Wiki source
WIKI_BASE_URL=https://terraria.wiki.gg
WIKI_LANG=zh
WIKI_USER_AGENT=terraria-rag-bot/0.1 (personal study; contact: you@example.com)

# Crawl rate limit (requests per second)
CRAWL_RPS=1.0
CRAWL_TIMEOUT_SEC=30

# Storage
DATA_DIR=./data
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=terraria_zh

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu              # 改成 mps（Apple Silicon GPU）或 cuda
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_LENGTH=1024

# Chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# API
API_HOST=0.0.0.0
API_PORT=8000
RETRIEVAL_TOP_K=8
